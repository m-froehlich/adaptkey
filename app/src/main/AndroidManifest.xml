<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- D-06: optional key-press vibration (default off). VIBRATE is a normal, non-privacy permission and
         does NOT declare INTERNET, so the provably-offline guarantee is unaffected. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- D-191: optional contact-derived email suggestions (default off, opt-in via Settings, runtime grant
         requested only at that moment - never on first use of an email field, since only an Activity can
         show that dialog, not this IME's own Service; see SettingsActivity's own KDoc). READ_CONTACTS is a
         dangerous permission declared here only so it CAN be requested when the user opts in - declaring it
         does not grant it. Contact data is read live at suggestion time and never persisted locally (that
         would be redundant with the address book itself) - still declared here, not INTERNET, so the
         provably-offline guarantee (no network access ever) is unaffected either way. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AdaptKey">

        <!-- The input method service. Bound by the system; protected by BIND_INPUT_METHOD. -->
        <service
            android:name=".AdaptKeyService"
            android:label="@string/ime_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Settings entry point: launcher activity and IME settings activity (C-01 … C-09). -->
        <activity
            android:name=".settings.SettingsActivity"
            android:label="@string/settings_title"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Blacklist editor (C-05), launched from the settings screen. -->
        <activity
            android:name=".settings.BlacklistActivity"
            android:label="@string/blacklist_title"
            android:exported="false" />

        <!-- Learned-words editor (D-177), launched from the settings screen. -->
        <activity
            android:name=".settings.LearnedWordsActivity"
            android:label="@string/learned_words_title"
            android:exported="false" />

        <!-- Saved usernames/emails editor (D-180), launched from the settings screen. -->
        <activity
            android:name=".settings.CredentialsActivity"
            android:label="@string/d142_credentials_title"
            android:exported="false" />

        <!-- Per-key secondary-symbol editor (C-08), launched from the settings screen. -->
        <activity
            android:name=".settings.LetterHintsActivity"
            android:label="@string/c08_editor_title"
            android:exported="false" />

        <!-- Calibration / onboarding (K-01), offered on first launch and from the settings screen. -->
        <activity
            android:name=".settings.CalibrationActivity"
            android:label="@string/k01_activity_title"
            android:exported="false" />

        <!-- Tier-3 mini-LLM model import (C-06), launched from the settings screen. -->
        <activity
            android:name=".settings.Tier3ModelActivity"
            android:label="@string/c06_model_title"
            android:exported="false" />

        <!-- Touch-pattern visualisation (D-24), launched from settings / the calibration result. -->
        <activity
            android:name=".settings.TouchModelActivity"
            android:label="@string/d24_title"
            android:exported="false" />

        <!-- Full feature overview (D-89), launched from the settings screen's Info & Privacy category. -->
        <activity
            android:name=".settings.FeatureOverviewActivity"
            android:label="@string/d89_title"
            android:exported="false" />

        <!-- D-139/D-110: diagnostic-log viewer/export, launched from the settings screen's Diagnostics category. -->
        <activity
            android:name=".settings.DiagnosticLogActivity"
            android:label="@string/d_diag_activity_title"
            android:exported="false" />

    </application>

</manifest>
