<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/d89_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- D-128: a compact, prominent callout - what "Adapt" in AdaptKey actually means - ahead of the
             ordinary feature list below, which already covers the same mechanisms individually. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="@color/key_background_special"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/d128_title"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/feature_overview_learning_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/d128_summary" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/feature_overview_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

    </LinearLayout>

</ScrollView>
